# Cloakli 라이선스 서버의 Wrangler 설정 예시입니다.
# 이 파일을 "wrangler.toml"로 복사한 뒤 아래 값들을 실제 값으로 채우세요.
# 실제 wrangler.toml은 .gitignore에 등록되어 있어 저장소에 커밋되지 않습니다.

name = "cloakli-license"
main = "src/index.js"
compatibility_date = "2024-01-01"
compatibility_flags = ["nodejs_compat"]

# `wrangler d1 create cloakli-license-db` 실행 후 출력되는 database_id를 넣으세요.
[[d1_databases]]
binding = "DB"
database_name = "cloakli-license-db"
database_id = "replace_me"

# 비밀이 아닌 값만 여기(vars)에 둡니다. 실제 비밀(secret)은 `wrangler secret put` 또는
# .dev.vars(로컬 전용, 커밋 금지)로 관리하세요: LEMONSQUEEZY_WEBHOOK_SECRET,
# LEMONSQUEEZY_STORE_ID, LEMONSQUEEZY_PRODUCT_ID, LEMONSQUEEZY_VARIANT_ID,
# LEMONSQUEEZY_CHECKOUT_URL, CLOAKLI_ADMIN_SECRET.
[vars]
ENVIRONMENT = "development"
# 콤마로 구분된 Chrome 확장 프로그램 ID 목록(32자, chrome://extensions에서 확인).
# production에서 비어 있으면 모든 요청이 거부됩니다("*" 허용 금지).
ALLOWED_EXTENSION_IDS = "replace_me_with_comma_separated_ids"
# "mock" | "lemonsqueezy". production 환경에서 "mock"이면 서버가 요청 처리 시점에
# 즉시 에러를 던집니다(코드에서 강제).
LICENSE_PROVIDER = "mock"

# production 배포용 설정이 필요하면 아래처럼 환경을 분리하세요.
# [env.production]
# [env.production.vars]
# ENVIRONMENT = "production"
# ALLOWED_EXTENSION_IDS = "실제_배포된_확장_ID"
# LICENSE_PROVIDER = "lemonsqueezy"
#
# [[env.production.d1_databases]]
# binding = "DB"
# database_name = "cloakli-license-db"
# database_id = "replace_me"
