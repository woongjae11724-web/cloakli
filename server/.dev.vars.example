# 로컬 개발용 비밀값 예시입니다. 이 파일을 ".dev.vars"로 복사한 뒤 실제 값을 채우세요.
# ".dev.vars"는 .gitignore에 등록되어 있어 저장소에 커밋되지 않습니다.
# 실제 값은 여기(로컬 파일)와 `wrangler secret put`(운영 배포) 두 곳에만 둡니다.
# Chrome 확장 프로그램 코드 안에는 이 값들을 절대 넣지 않습니다.

LEMONSQUEEZY_WEBHOOK_SECRET=replace_me
LEMONSQUEEZY_STORE_ID=replace_me
LEMONSQUEEZY_PRODUCT_ID=replace_me
LEMONSQUEEZY_VARIANT_ID=replace_me
LEMONSQUEEZY_CHECKOUT_URL=https://example.lemonsqueezy.com/checkout/replace_me
CLOAKLI_ADMIN_SECRET=replace_me
ENVIRONMENT=development
